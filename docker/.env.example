# ═══════════════════════════════════════════════════════
#  River Algorithm — Docker 配置
#  River Algorithm — Docker Configuration
# ═══════════════════════════════════════════════════════
#  首次使用 | First time setup:
#    cp .env.example .env
#    编辑 .env 填入你的配置 | Edit .env with your settings
#    docker compose up


# ─── 语言 | Language | 言語 ──────────────────────────
#  zh = 中文 | en = English | ja = 日本語
LANGUAGE=en


# ─── AI 模型 | AI Model ─────────────────────────────
#
#  选择 AI 提供商 | Choose AI provider:
#    openai = 远端 API（OpenAI / DeepSeek / Groq 等任何兼容接口）
#    local  = 本地 Ollama（需要先在宿主机安装 Ollama）
#
#  openai = Remote API (OpenAI / DeepSeek / Groq / any compatible API)
#  local  = Local Ollama (install Ollama on host machine first)
LLM_PROVIDER=openai

#  ── 远端 API 配置（当 LLM_PROVIDER=openai）──
#  ── Remote API config (when LLM_PROVIDER=openai) ──
#  支持所有 OpenAI 兼容接口，只需修改下面三项
#  Works with any OpenAI-compatible API, just change these three:
#
#  OpenAI:    OPENAI_API_BASE=https://api.openai.com    OPENAI_MODEL=gpt-4o-mini
#  DeepSeek:  OPENAI_API_BASE=https://api.deepseek.com  OPENAI_MODEL=deepseek-chat
#  Groq:      OPENAI_API_BASE=https://api.groq.com      OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

#  ── 本地 Ollama 配置（当 LLM_PROVIDER=local）──
#  ── Local Ollama config (when LLM_PROVIDER=local) ──
#  先安装 Ollama 并拉取模型 | Install Ollama and pull model first:
#    ollama pull qwen2.5:14b
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_API_BASE=http://host.docker.internal:11434


# ─── 演示数据 | Demo Data ────────────────────────────
#  启动时导入 demo.json 演示对话（可自定义编辑 demo.json）
#  Load demo.json sample conversations on startup (edit demo.json to customize)
DEMO_MODE=true
#  是否自动运行 River Algorithm 处理演示数据（会调用 LLM，需要几分钟）
#  Auto-process demo with River Algorithm on startup (uses LLM, takes minutes)
#  设为 false 则手动运行 | If false, run manually:
#    docker compose exec riverhistory bash -c "cd /app_work && python run.py demo"
DEMO_PROCESS=false


# ─── 睡眠（记忆整理）| Sleep (Memory Consolidation) ──
#  AI 定期整理对话记忆，提取用户画像
#  AI periodically consolidates chat memories and extracts user profiles
#
#  cron = 每天定时运行 | Daily at SLEEP_CRON_HOUR (default: midnight)
#  auto = 每次聊天后自动运行 | After every chat message
#  off  = 仅手动运行 | Manual only: curl -X POST http://localhost:8400/sleep
SLEEP_MODE=cron
SLEEP_CRON_HOUR=0


# ─── Telegram Bot ────────────────────────────────────
#  通过 Telegram 和 AI 聊天（可选）
#  Chat with AI via Telegram (optional)
#  在 Telegram 找 @BotFather 创建 Bot 获取 token
#  Create bot: @BotFather on Telegram → get token
TELEGRAM_BOT_TOKEN=
#  限制谁可以使用（逗号分隔的用户 ID，留空=所有人）
#  Restrict access (comma-separated user IDs, empty = everyone)
TELEGRAM_ALLOWED_USERS=


# ─── Discord Bot ─────────────────────────────────────
#  通过 Discord 和 AI 聊天（可选）
#  Chat with AI via Discord (optional)
#  在 Discord Developer Portal 创建 Bot 获取 token
#  Create bot in Discord Developer Portal → get token
DISCORD_BOT_TOKEN=
