# ═══════════════════════════════════════════════════════
#  Riverse — Docker Configuration
# ═══════════════════════════════════════════════════════
#  cp .env.example .env
#  Edit .env with your settings
#  docker compose up -d


# ─── Language ────────────────────────────────────────
#  zh = 中文 | en = English | ja = 日本語
LANGUAGE=en


# ─── AI Model ────────────────────────────────────────
#
#  openai = Remote API (OpenAI / DeepSeek / Groq / any OpenAI-compatible API)
#  local  = Local Ollama (install Ollama on host machine first)
LLM_PROVIDER=openai

#  ── Remote API (when LLM_PROVIDER=openai) ──
#  Works with any OpenAI-compatible API, just change these three:
#
#  OpenAI:    OPENAI_API_BASE=https://api.openai.com    OPENAI_MODEL=gpt-4o-mini
#  DeepSeek:  OPENAI_API_BASE=https://api.deepseek.com  OPENAI_MODEL=deepseek-chat
#  Groq:      OPENAI_API_BASE=https://api.groq.com      OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

#  ── Local Ollama (when LLM_PROVIDER=local) ──
#  Install Ollama and pull model first: ollama pull qwen2.5:14b
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_API_BASE=http://host.docker.internal:11434


# ─── Demo Data ───────────────────────────────────────
#  Load built-in demo conversations on startup (great for first-time users)
#  true = import demo conversations into database
DEMO_MODE=true
#  Auto-process demo with River Algorithm (calls LLM, takes a few minutes)
#  true = auto-run sleep pipeline | false = run manually later
DEMO_PROCESS=false


# ─── Sleep (Memory Consolidation) ────────────────────
#  cron = Daily at SLEEP_CRON_HOUR (default: midnight)
#  auto = After every chat message
#  off  = Manual only: curl -X POST http://localhost:8400/sleep
SLEEP_MODE=cron
SLEEP_CRON_HOUR=0


# ─── Telegram Bot (optional) ────────────────────────
#  Create bot: @BotFather on Telegram → get token
TELEGRAM_BOT_TOKEN=
#  Restrict access (comma-separated user IDs, empty = everyone)
TELEGRAM_ALLOWED_USERS=


# ─── Discord Bot (optional) ─────────────────────────
#  Create bot in Discord Developer Portal → get token
DISCORD_BOT_TOKEN=
